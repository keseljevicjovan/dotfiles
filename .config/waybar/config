{
    "height": 24, // Waybar height (to be removed for auto height)
    "margin-top": 3,
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,
    "spacing": 5, // Gaps between modules (4px)
    "modules-left": [ "cpu", "memory"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["pulseaudio", "network",  "clock"],
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "1": "ΎΕΣ",
        "2": "ΎΕΣ",
        "3": "ΎΕΣ",
        "4": "ΎΕΣ",
        "5": "ΎΕΣ",
        "5": "ΎΕΣ",
        "6": "ΎΕΣ",
        "7": "ΎΕΣ",
        "8": "ΎΕΣ",
        "9": "ΎΕΣ",
        "0": "ΎΕΣ",
        "urgent": "ΎΒς",
        "active": "ΎΕΣ",
        "default": "ΎΕΣ"
      }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "<span color='#bf616a'>ΎΑΩ </span>{:%I:%M %p}",
        "format-alt": "<span color='#bf616a'>ΎΒ│ </span>{:%a %b %d}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "cpu": {
      "interval": 1,
      "format": "Ύαο {usage}%",
      "max-length": 100,
      "on-click": "",
    },
    "gpu": {
      "interval": 1,
      "format": "Ύαο {usage}%",
      "max-length": 100,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "Ύας {}%",
        "format-alt":"<ΎΣ▓ {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon} {percent}%",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
        "on-click": "",
    },
    "network": {
        "format-wifi": "Ύςρ {signalStrength}%",
        "format-ethernet": "Ύςρ  connected",
        "format-disconnected": "Ύςσ",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "ΎΑξ ΎΛΦ {volume}%",
        "format-bluetooth-muted": "ΎςΑ ΎΛΦ",
        "format-muted": "ΎςΑ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "ΎΛΦ {status}",
    },

 
}

